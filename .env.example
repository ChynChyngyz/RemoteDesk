# --- App Settings ---

# Django Secret Key (keep this secret in production!)

SECRET_KEY=placeholder-secret-key
# Debug mode (set to False in production)
DEBUG=True

# Allowed hosts (comma separated)
ALLOWED_HOSTS=*,localhost,127.0.0.1

# --- Database Settings ---
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=secret_password
DB_HOST=db
DB_PORT=5432

# --- Redis / Cache Settings ---
# Redis URL for channel layers and caching
REDIS_URL=redis://redis:6379/0

# ========================================================== #

# --- TURN / WebRTC Settings ---

# Ports for the Coturn server
COTURN_PORT=3478
COTURN_TLS_PORT=5349

# Shared secret for TURN authentication
COTURN_SECRET=SUPER_SECRET_KEY

# Realm/Domain for the TURN server
COTURN_REALM=yourdomain.com

# Public IP of the server for relaying
COTURN_RELAY_IP=1.2.3.4

# --- Nginx / Domains ---
# Primary domain name
DOMAIN_NAME=yourdomain.com
